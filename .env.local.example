# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `.env.local.example` is the source of truth
# for which variables exist.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Found in: Supabase dashboard -> Project Settings -> API
# The URL + anon key are public (safe to ship to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key is server-only. NEVER prefix with NEXT_PUBLIC_.
# Not strictly required for the auth slice, but you'll want it as soon as
# you write server code that bypasses RLS (e.g. admin tasks).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL used to build the OAuth redirect. In Vercel this is
# automatically set to https://<deployment>.vercel.app; locally it should be
# http://localhost:3000. Leave unset and the code falls back to request origin.

# Dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production
# NEXT_PUBLIC_SITE_URL=

# Workspace domain that is allowed to sign in. Enforced server-side in the
# OAuth callback via Google's `hd` claim.
ALLOWED_WORKSPACE_DOMAIN=ubcbiztech.com
