# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; `.env.local.example` is the source of truth
# for which variables exist.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Found in: Supabase dashboard -> Project Settings -> API
# The URL + anon key are public (safe to ship to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key is server-only. NEVER prefix with NEXT_PUBLIC_.
# Not strictly required for the auth slice, but you'll want it as soon as
# you write server code that bypasses RLS (e.g. admin tasks).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct Postgres connection string — used by Drizzle for migrations and
# server-side queries that bypass the Supabase client. Found in:
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI).
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Public base URL used to build the OAuth redirect. In Vercel this is
# automatically set to https://<deployment>.vercel.app; locally it should be
# http://localhost:3000. Leave unset and the code falls back to request origin.

# Dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production
# NEXT_PUBLIC_SITE_URL=https://biztech-partnerships.vercel.app/

# Workspace domain that is allowed to sign in. Enforced server-side in the
# OAuth callback via Google's `hd` claim.
ALLOWED_WORKSPACE_DOMAIN=ubcbiztech.com

# ---------------------------------------------------------------------------
# Google OAuth (for direct API access: Drive, Docs, Gmail)
# ---------------------------------------------------------------------------
# OAuth 2.0 credentials from Google Cloud Console -> APIs & Services -> Credentials.
# These should match (or be the same app as) what is configured in Supabase's
# Google provider settings.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 32-byte AES-256-GCM key for encrypting refresh tokens at rest.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key-here

# Optional: separate HMAC secret for signing OAuth state params (CSRF).
# Falls back to GOOGLE_CLIENT_SECRET if not set.
# GOOGLE_STATE_SECRET=your-state-secret-here
